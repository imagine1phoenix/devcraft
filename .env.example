# .env.example — Required Environment Variables for MarketMind AI
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ═══════════════════════════════════════════
# AUTHENTICATION
# ═══════════════════════════════════════════

# NextAuth.js secret — generate with: openssl rand -hex 32
AUTH_SECRET=

# Google OAuth (optional — for social login)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth (optional — for social login)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ═══════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════

# Neon PostgreSQL connection string
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# ═══════════════════════════════════════════
# AI PROVIDERS
# ═══════════════════════════════════════════

# Google Gemini API Key (PRIMARY AI provider)
# Get from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# OpenAI API Key (FALLBACK provider — optional for Phase 1)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ═══════════════════════════════════════════
# AI BACKEND (FastAPI)
# ═══════════════════════════════════════════

# FastAPI backend URL (where full_stockai_analysis runs)
# Local dev: http://localhost:8000
# Production: https://your-fastapi-service.railway.app (or similar)
FASTAPI_BACKEND_URL=http://localhost:8000

# Internal API key for Next.js → FastAPI authentication
# Generate with: openssl rand -hex 32
FASTAPI_API_KEY=

# ═══════════════════════════════════════════
# FINANCIAL DATA APIs
# ═══════════════════════════════════════════

# Alpha Vantage API Key (FREE tier: 25 requests/day)
# Get from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Polygon.io API Key (PAID — Phase 2, for real-time data)
# Get from: https://polygon.io/dashboard/signup
POLYGON_API_KEY=

# Finnhub API Key (FREE tier: 60 requests/min)
# Get from: https://finnhub.io/register
FINNHUB_API_KEY=

# NewsAPI.org API Key (FREE tier: 100 requests/day — dev only)
# Get from: https://newsapi.org/register
NEWS_API_KEY=

# ═══════════════════════════════════════════
# CACHING / RATE LIMITING
# ═══════════════════════════════════════════

# Upstash Redis REST URL
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST Token
UPSTASH_REDIS_REST_TOKEN=

# ═══════════════════════════════════════════
# FILE STORAGE
# ═══════════════════════════════════════════

# Vercel Blob token (for chart image uploads)
# Auto-provisioned when you add Vercel Blob to your project
BLOB_READ_WRITE_TOKEN=

# ═══════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════

# Base URL of the application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application name (displayed in UI)
NEXT_PUBLIC_APP_NAME=MarketMind AI

# ═══════════════════════════════════════════
# RATE LIMITS (configurable)
# ═══════════════════════════════════════════

# Free tier: AI requests per hour
RATE_LIMIT_FREE_AI_PER_HOUR=10

# Pro tier: AI requests per hour
RATE_LIMIT_PRO_AI_PER_HOUR=100

# Alpha Vantage: requests per minute
RATE_LIMIT_ALPHA_VANTAGE_PER_MIN=5

# Alpha Vantage: requests per day
RATE_LIMIT_ALPHA_VANTAGE_PER_DAY=25
